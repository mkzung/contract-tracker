# Copy to .env and fill with real values. .env is git-ignored.

# --- IMAP (any provider, here shown for Mail.ru for Business) ---
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=tracker@example.com
IMAP_PASSWORD=<imap_app_password>
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=300

# --- Database ---
# SQLite (default): file path. Postgres: postgresql+psycopg2://user:pw@host/db
DATABASE_URL=sqlite:///./data/tracker.db

# --- OpenAI API ---
# Any chat-completions-compatible model. JSON-mode is required.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/tracker.log

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# --- Subject parser ---
# Prefix used to identify contract-approval mailings. Tweak to match your convention.
SUBJECT_PREFIX=На согласование
